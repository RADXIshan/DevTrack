generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(uuid())
  name         String
  email        String            @unique
  passwordHash String
  createdAt    DateTime          @default(now())
  problems     ProblemEntry[]
  sheets       PredefinedSheetProgress[]
}

model ProblemEntry {
  id             String    @id @default(uuid())
  title          String
  leetcodeUrl    String?
  difficulty     String?
  dataStructure  String?
  algorithm      String?
  pattern        String?
  approachThought String?  @db.Text
  mode           String    @default("DSA") // "DSA", "DEV", "AI"
  completedAt    DateTime  @default(now())
  
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PredefinedSheetProgress {
  id           String    @id @default(uuid())
  sheetName    String    // e.g., "NeetCode150", "StriverA2Z"
  problemId    String    // The ID or clear name of the problem in that sheet
  status       String    @default("INCOMPLETE") // "INCOMPLETE", "COMPLETED", "REVISIT"
  
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sheetName, problemId])
}
